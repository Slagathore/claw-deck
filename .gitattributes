# Normalize line endings across platforms — eliminates noisy CRLF/LF diffs.
* text=auto eol=lf

# Binary files — never normalize.
*.png  binary
*.jpg  binary
*.jpeg binary
*.gif  binary
*.webp binary
*.ico  binary
*.icns binary
*.pfx  binary
*.cer  binary
*.crt  binary
*.exe  binary
*.dll  binary
*.so   binary
*.dylib binary
*.node binary
*.wasm binary
*.zip  binary
*.gz   binary
*.tar  binary
*.7z   binary
*.blockmap binary