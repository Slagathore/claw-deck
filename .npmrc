# This repo intentionally runs Vite 8 ahead of some plugins' declared peer
# ranges (@vitejs/plugin-react 4.x caps at vite ^7 — see the note in
# vite.config.ts). Fresh installs (CI, new clones) would fail ERESOLVE without
# this; the combination is known-good (typecheck, 367 tests, packaged builds).
legacy-peer-deps=true
