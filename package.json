{
  "name": "claw-deck",
  "version": "0.1.0",
  "description": "Desktop GUI for OpenClaw + Claude Code over Ollama, with vision, screenshots, secure upgrades, and history.",
  "author": {
    "name": "Cole",
    "email": "cole@clawdeck.local"
  },
  "license": "MIT",
  "main": "dist-electron/main.js",
  "bin": {
    "claw-deck": "bin/claw-deck.js"
  },
  "scripts": {
    "dev": "concurrently -k \"vite\" \"npm:dev:electron\"",
    "dev:electron": "wait-on tcp:5273 && tsc -p electron/tsconfig.json && cross-env CLAW_DEV=1 electron .",
    "build:renderer": "vite build",
    "build:electron": "tsc -p electron/tsconfig.json",
    "build": "npm run build:renderer && npm run build:electron",
    "start": "npm run build && electron .",
    "stage:source": "node scripts/stage-source.mjs",
    "dist": "npm run build && npm run stage:source && electron-builder --win nsis portable --publish never",
    "dist:portable": "npm run build && npm run stage:source && electron-builder --win portable --publish never",
    "dist:nsis": "npm run build && npm run stage:source && electron-builder --win nsis --publish never",
    "cert:dev": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/make-dev-cert.ps1",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc -p tsconfig.json --noEmit && tsc -p electron/tsconfig.json --noEmit",
    "lint:eslint": "eslint .",
    "lint:all": "npm run lint && npm run lint:eslint",
    "postinstall": "electron-builder install-app-deps || echo skipped"
  },
  "dependencies": {
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/xterm": "^6.0.0",
    "better-sqlite3": "^12.11.1",
    "cytoscape": "^3.34.0",
    "node-pty": "^1.1.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "sqlite-vec": "^0.1.9",
    "zustand": "^4.5.5"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/better-sqlite3": "^7.6.11",
    "@types/cytoscape": "^3.21.9",
    "@types/node": "^20.14.10",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "concurrently": "^8.2.2",
    "cross-env": "^10.1.0",
    "electron": "^42.4.0",
    "electron-builder": "^26.15.3",
    "eslint": "^10.6.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "globals": "^17.7.0",
    "typescript": "^5.5.4",
    "typescript-eslint": "^8.62.0",
    "vite": "^8.0.16",
    "vitest": "^4.1.9",
    "wait-on": "^7.2.0"
  },
  "build": {
    "appId": "com.cole.clawdeck",
    "productName": "Claw Deck",
    "files": [
      "dist/**/*",
      "dist-electron/**/*",
      "bin/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "staging-source",
        "to": "source"
      }
    ],
    "asarUnpack": [
      "**/node_modules/node-pty/**"
    ],
    "directories": {
      "buildResources": "public",
      "output": "dist-installer"
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ],
      "artifactName": "${productName}-${version}-${arch}.${ext}",
      "certificateSubjectName": "Claw Deck Dev",
      "signingHashAlgorithms": [
        "sha256"
      ]
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "deleteAppDataOnUninstall": false
    },
    "portable": {
      "artifactName": "${productName}-${version}-portable-${arch}.${ext}"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "Slagathore",
        "repo": "claw-deck"
      }
    ]
  }
}
